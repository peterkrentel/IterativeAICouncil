# IterativeAICouncil Configuration
# Copy this file and fill in your API keys

# OpenAI API Key (required for ChatGPT agent)
OPENAI_KEY=your_openai_api_key_here

# Anthropic API Key (required for Claude agent)
CLAUDE_KEY=your_claude_api_key_here

# Optional: Copilot token or Augment credentials
# COPILOT_TOKEN=your_token_here

# Orchestrator Configuration
AI_DIR=./ai
MAX_ITERATIONS=5
CURRENT_PHASE=1
